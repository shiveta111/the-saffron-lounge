{
  "name": "backend",
  "version": "1.0.0",
  "description": "Comprehensive e-commerce system with Node.js, Express.js, and TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only --watch src src/server.ts",
    "start": "cross-env RUN_STARTUP_CHECKS=true node dist/server.js",
    "start:quick": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:db": "node test-db-connection.js",
    "db:generate": "npx --yes --package=prisma@6.15.0 prisma generate",
    "db:migrate": "npx --yes --package=prisma@6.15.0 prisma migrate dev",
    "db:push": "npx --yes --package=prisma@6.15.0 prisma db push",
    "db:studio": "npx --yes --package=prisma@6.15.0 prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:seed-admin": "ts-node prisma/seed-admin-data.ts",
    "db:setup": "node setup-db.js",
    "db:verify": "node scripts/verify-database-setup.js",
    "db:cleanup:menu-orphans": "node scripts/cleanup-orphaned-menu-products.js",
    "db:cleanup:menu-orphans:dry": "node scripts/cleanup-orphaned-menu-products.js --dry-run",
    "migrate:menu": "ts-node scripts/migrate-menu-data.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "typescript",
    "prisma",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.0.0",
    "@types/node-cache": "^4.1.3",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.14.4",
    "node-cache": "^5.1.2",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.4",
    "qs": "^6.14.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.18.13",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.16",
    "@types/passport-facebook": "^3.0.3",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prisma": "^6.15.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
